---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { SITE } from "../site";
---

<BaseLayout>
  <section class="hero">
    <h1>{SITE.name}</h1>
    <p class="lead muted">
      Aspiring quantitative trader / researcher. This site collects my projects,
      browser games, reading, and writing.
    </p>
    <SocialLinks />
  </section>
</BaseLayout>

<style>
  .hero {
    max-width: 42rem;
    padding-block: 1.5rem 1rem;
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0 0 0.5rem;
  }
  .lead {
    font-size: 1.15rem;
    margin: 0 0 1.5rem;
  }
</style>
